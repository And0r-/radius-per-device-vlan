# FreeRADIUS Stack — copy to .env and fill in your values
# Generate secrets: openssl rand -base64 18 | tr -d '/+=' | head -c 24

# PostgreSQL
POSTGRES_USER=radius
POSTGRES_PASSWORD=CHANGE_ME_generate_random
POSTGRES_DB=radius

# RADIUS shared secret (between UniFi AP and RADIUS server)
RADIUS_SECRET=CHANGE_ME_generate_random

# pfSense VLAN API (must match PFSENSE_API_KEY on the firewall)
PFSENSE_API_URL=https://192.168.4.1/api/api.php
PFSENSE_API_KEY=CHANGE_ME_generate_random

# VLAN limit (max VLANs that can be created, safety cap)
VLAN_LIMIT=100

# SSID to VLAN type mapping
# Format: type:SSIDname,type:SSIDname,...
# Types: e=enterprise, o=offline, g=guest, i=internet (default for unmatched)
SSID_MAP=e:DaathNet-Secure,o:DaathNet-IoT-Offline,g:DaathNet-Guest
