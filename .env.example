# FreeRADIUS Stack — copy to .env and fill in your values
# Generate secrets: openssl rand -base64 18 | tr -d '/+=' | head -c 24

# PostgreSQL
POSTGRES_USER=radius
POSTGRES_PASSWORD=CHANGE_ME_generate_random
POSTGRES_DB=radius

# RADIUS shared secret (between UniFi AP and RADIUS server)
RADIUS_SECRET=CHANGE_ME_generate_random
