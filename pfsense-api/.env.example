# pfSense VLAN API — Configuration
# Copy to .env on the pfSense machine

# API secret (must match PFSENSE_API_KEY in RADIUS stack .env)
PFSENSE_API_KEY=CHANGE_ME_generate_random

# Parent interface for VLANs (trunk port to UniFi AP)
PFSENSE_PARENT_IF=ix2

# Listen address:port (use infra interface IP, not 0.0.0.0)
PFSENSE_LISTEN=192.168.4.1:9444
